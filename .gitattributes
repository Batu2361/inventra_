# Normalize line endings to LF on all platforms
* text=auto eol=lf

# Java / Kotlin
*.java    text eol=lf
*.kt      text eol=lf
*.kts     text eol=lf

# Web
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.jsx     text eol=lf
*.css     text eol=lf
*.html    text eol=lf
*.json    text eol=lf

# Config / Scripts
*.yml     text eol=lf
*.yaml    text eol=lf
*.sh      text eol=lf
*.sql     text eol=lf
*.conf    text eol=lf
Dockerfile text eol=lf
gradlew   text eol=lf

# Windows line endings for bat files
*.bat     text eol=crlf
gradlew.bat text eol=crlf

# Binary — never modify
*.jar     binary
*.png     binary
*.jpg     binary
*.ico     binary
*.woff    binary
*.woff2   binary
